# 1. Visual Studio 專屬的個人與暫存檔案 (必留)
.vs/                        # VS 2022 在本地產生的核心快取資料夾（極重要，不擋 Git 會爆）
*.suo                       # 紀錄你開了哪些視窗、斷點設在哪的個人設定
*.user                      # 本地專案的使用者偏好設定
*.sln.docstates             # 視窗開啟狀態紀錄
.localhistory/              # 本地歷史紀錄資料夾

# ==========================================
# 2. 建置與編譯產物 (Build Results)
# ==========================================
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/                      # 你之前專案檔卸載的元兇，一定要擋掉
[Oo]ut/
*.tmp

# ==========================================
# 3. 前端 Node.js / React 生態系 (必留)
# ==========================================
node_modules/               # 絕對不能傳上去的套件庫
.sass-cache/                # 如果有用到 CSS 預處理器
.env                        # 你的本地環境變數隱私檔（雖然原本沒有，強烈建議加上）

# ==========================================
# 4. 後端 Python 相關 (必留)
# ==========================================
__pycache__/                # Python 自動生成的快取資料夾
*.pyc                       # Python 編譯位元組碼
instance/                   # Flask 的本地實例資料夾
*.db                        # 本地測試用的資料庫檔案（如 SQLite）

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.ntvs*
*.njsproj
*.sln
*.sw?
